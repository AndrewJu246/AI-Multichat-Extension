{
  "manifest_version": 3,
  "name": "Multichat",
  "version": "1.1",
  "description": "Sends prompts and swaps answers between AI tabs.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["tabs", "scripting", "clipboardWrite", "clipboardRead", "storage", "unlimitedStorage"],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://chat.deepseek.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*", "*://claude.ai/*", "*://gemini.google.com/*", "*://chat.deepseek.com/*"],
      "js": ["content.js"]
    }
  ]
}
